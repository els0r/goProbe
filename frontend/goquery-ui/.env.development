# GQ_API_BASE_URL is intentionally empty: the browser sends /_query* as relative
# paths, which the webpack-dev-server proxy forwards to the backend.
# Override to a full URL (e.g. http://remote-host:8145) to skip the proxy.
GQ_API_BASE_URL=

# Comma-separated list of host resolver options shown in Settings
HOST_RESOLVER_TYPES=string,gethosts

# Enable Server-Sent Events by default on load
SSE_ON_LOAD=true
